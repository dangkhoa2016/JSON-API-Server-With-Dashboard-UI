ADMIN_SECRET=             # Admin session signing secret (required, generate with: openssl rand -hex 32)

# ── Backend ─────────────────────────────────────────────────────
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # libSQL connection string (file:./local.db or libsql://...)

# ── Redis (optional) ───────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=60


# ── Debug sql queries ──
DEBUG_SQL=true

# ── CORS (optional) ────────────────────────────────────────────
CORS_ORIGINS=*            # Comma-separated allowed origins (e.g., http://localhost:5173,https://example.com)

# ── Rate Limiting (optional) ───────────────────────────────────
RATE_LIMIT_ENABLED=false
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
